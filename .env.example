# ─── Database (Neon / Vercel Postgres) ───────────────────────────────────────
POSTGRES_URL="postgresql://user:password@host/dbname?sslmode=require"
POSTGRES_URL_UNPOOLED="postgresql://user:password@host/dbname?sslmode=require"

# ─── Authentication (Better Auth) ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="your-256-bit-secret-here"
BETTER_AUTH_URL="https://your-domain.vercel.app"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ─── Resend (Transactional email) ─────────────────────────────────────────────
RESEND_API_KEY="re_your_key_here"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
RESEND_WEBHOOK_SECRET="your_svix_signing_secret"

# ─── AhaSend (Bulk campaign email) ────────────────────────────────────────────
AHASEND_API_KEY="your_ahasend_key"
AHASEND_FROM_EMAIL="campaigns@yourdomain.com"
AHASEND_WEBHOOK_SECRET="your_ahasend_hmac_secret"

# ─── Email sending ────────────────────────────────────────────────────────────
EMAIL_FROM_ADDRESS="noreply@yourdomain.com"

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_your_key"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_your_key"
STRIPE_WEBHOOK_SECRET="whsec_your_secret"
STRIPE_PRICE_ID_STANDARD="price_standard_id"
STRIPE_PRICE_ID_CHRMNEXUS="price_chrmnexus_id"
STRIPE_PRICE_ID_CREDITS="price_credits_id"

# ─── CHRMNEXUS Jobs Board ─────────────────────────────────────────────────────
CHRMNEXUS_API_URL="https://www.cloudsourcehrm.com/api"
CHRMNEXUS_API_KEY="your_chrmnexus_api_key"

# ─── Security (generate each with: openssl rand -hex 32) ──────────────────────
HMAC_SECRET="your-hmac-secret"
CRON_SECRET="your-cron-secret"
